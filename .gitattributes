# Normalize line endings to LF in the repo and working tree on every platform.
# Keeps Windows checkouts consistent with the Linux CI runner.
* text=auto eol=lf

# Treat binary assets as binary (no EOL conversion, no diff).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.woff binary
*.woff2 binary
