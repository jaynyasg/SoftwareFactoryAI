# Dependencies
node_modules/

# Next.js build output. `next-env.d.ts` is regenerated by Next on every
# dev/build; we commit types/next-ambient.d.ts instead so a fresh-checkout
# typecheck does not depend on build artifacts.
.next/
out/
next-env.d.ts

# Production build / dist
build/
dist/

# TypeScript incremental
*.tsbuildinfo

# Local SQLite databases (dev/test/e2e). These resolve under prisma/ because
# Prisma resolves a relative `file:` URL against the schema directory.
*.db
*.db-journal
*.db-wal
*.db-shm
prisma/*.db
prisma/*.db-journal
prisma/*.db-wal
prisma/*.db-shm

# Generated Prisma client (only if a custom `output` path is configured;
# the default output lives in node_modules and is already ignored).
src/generated/

# Test / coverage artifacts
coverage/
playwright-report/
test-results/

# Local environment
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
